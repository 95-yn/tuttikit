# ===== LLM Provider =====
# 选择默认 Provider: anthropic | openai | deepseek | qwen | doubao | hunyuan | glm | kimi | mock
LLM_PROVIDER=mock
# 主 provider 限流/5xx 时自动降级链（逗号分隔；未配置 key 的项自动跳过）
# LLM_FALLBACK_CHAIN=deepseek,qwen,kimi,mock

# Anthropic
#   2026-04 起 Sonnet 4.6 / Opus 4.7 都原生 1M context、无长上下文溢价
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 旗舰可选 claude-opus-4-7（$5/$25 per 1M tokens）

# OpenAI
#   2026 Codex CLI 默认 GPT-5.5（1M context）；旧 gpt-4o-mini 仍可用但已为上代
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-5
OPENAI_BASE_URL=https://api.openai.com/v1
# 编程任务可选 gpt-5-codex；轻量任务可选 gpt-4o-mini

# DeepSeek（OpenAI 兼容协议）
#   ⚠️ 老 deepseek-chat / deepseek-reasoner 将在 2026-07-24 完全退役
#   迁移到 V4：deepseek-v4-pro（旗舰）/ deepseek-v4-flash（性价比，对应原 deepseek-chat）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 阿里通义 Qwen（阿里云百炼 / DashScope）──
#   2026-05-21 旗舰是 qwen3.7-max；qwen3.5-plus（1M）为高性价比；qwen-plus 是更老的稳定档
# 拿 key: https://bailian.console.aliyun.com/?apiKey=1
QWEN_API_KEY=
QWEN_MODEL=qwen3.7-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 字节豆包 Doubao（火山引擎 Ark）──
#   2026 主力 doubao-seed-1.6 / doubao-seed-2 都是 256K context
# 拿 key: https://www.volcengine.com/docs/82379
# model 可以是公开 model id（doubao-seed-1.6）或火山 endpoint id（ep-xxx）
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-1.6
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 腾讯混元 Hunyuan ──
#   2026 主力 Hunyuan TurboS（256K，Mamba-Transformer 混合架构）/ Hunyuan T1（深度思考）
# 拿 key: https://cloud.tencent.com/document/product/1729
HUNYUAN_API_KEY=
HUNYUAN_MODEL=hunyuan-turbos-latest
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# ── 智谱 GLM ──
#   2026-04-07 最新 GLM-5.1（200K，744B MoE 开源），GLM-5 是基础版；老 glm-4-plus 仍可用
# 拿 key: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=
GLM_MODEL=glm-5.1
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── Moonshot Kimi ──
#   2026-04-20 最新 Kimi K2.6（262K，1T 参数 MoE）；老 moonshot-v1 系列仍可用
# 拿 key: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.6
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ===== Server =====
# 后端固定 3001；Next.js 前端默认占用 3000
PORT=3001
LOG_LEVEL=info
# Next.js dev 同源；多个来源用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Memory =====
LONG_TERM_MEMORY_PATH=./data/long_term_memory.json
SHORT_TERM_MAX_TURNS=20

# ===== fileSystem tool 写入限制 =====
# 写入只允许在这些根目录下（逗号分隔，相对项目根）；默认 data,tmp,output
# FS_WRITE_ALLOWLIST=data,tmp,output
# 在默认 denylist（.env / package.json / .git 等）之外追加的禁止路径
# FS_WRITE_DENYLIST_EXTRA=secrets/,credentials.json

# ===== Safety hooks =====
# 默认已内置 14 条危险模式（rm -rf / fork bomb / DROP DATABASE / curl|sh 等）
# 想再加自定义规则，按 JSON array 写：每条 { name, reason, pattern, flags? }
# 注意正则里的 \ 在 .env 里要双重转义：`\s` 写成 `\\\\s`
# SAFETY_EXTRA_RULES='[{"name":"no-prod-kubectl","reason":"禁止 LLM 对 prod 集群下 kubectl apply","pattern":"kubectl\\\\s+apply.*prod","flags":"i"}]'

# ===== Debug 端点 =====
# GET /debug/hooks 返回所有 safety / approval regex 规则——pattern.source 是敏感信息
# 防御：
#   - NODE_ENV=production 且未设 DEBUG_TOKEN 时直接 404
#   - 设了 DEBUG_TOKEN：请求需带 Authorization: Bearer <token>
#   - 未设 DEBUG_TOKEN：仅允许 localhost 访问
# DEBUG_TOKEN=请设一个长随机串

# ===== Approval hooks（动态审批，灰色操作走人工） =====
# 默认已内置 5 条审批规则（git reset --hard / git push --force / 写系统路径等）
# 用户在 UI 点 Approve 才执行；Deny / 超时 / 离线则给 LLM 报错让它改方案
APPROVAL_TIMEOUT_MS=30000
# 添加自定义审批规则，格式同 SAFETY_EXTRA_RULES
# APPROVAL_EXTRA_RULES='[{"name":"deploy-prod","reason":"prod 部署需人工确认","pattern":"deploy.*prod","flags":"i"}]'
