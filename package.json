{
  "name": "tuttikit",
  "version": "0.1.0",
  "private": true,
  "description": "可切换模型的多 Agent 协作框架（Tool Use / Memory / Streaming / Observability）— monorepo",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:server": "pnpm --filter @tuttikit/server run dev",
    "dev:web": "pnpm --filter @tuttikit/web run dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel --stream run start",
    "chat": "pnpm --filter @tuttikit/server run chat",
    "test": "pnpm --filter @tuttikit/server run test",
    "test:parallel": "pnpm --filter @tuttikit/server run test:parallel",
    "lint": "pnpm --filter @tuttikit/server run typecheck && pnpm --filter @tuttikit/web exec tsc --noEmit",
    "typecheck": "pnpm run lint",
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true"
  },
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.24.0"
}
